generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Modelos para NextAuth.js
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // Para credenciais manuais
  role          String    @default("USER") // USER, ADMIN
  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Booking {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  // Detalhes da Viagem
  flightOfferId String?  // ID do Amadeus
  provider      String   // 'amadeus', 'flixbus', etc
  origin        String
  destination   String
  departureDate DateTime
  arrivalDate   DateTime
  duration      String
  carrierCode   String
  
  // Detalhes Financeiros
  amount        Float
  currency      String   @default("EUR")
  paymentId     String?  // ID do Stripe/Pagamento
  status        String   @default("PENDING") // PENDING, PAID, CANCELLED, FAILED
  
  // Dados dos Passageiros (Armazenado como JSON para flexibilidade)
  passengers    Json
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model SearchLog {
  id          String   @id @default(cuid())
  origin      String
  destination String
  date        DateTime
  source      String
  latencyMs   Int
  ipHash      String?
  createdAt   DateTime @default(now())
}
